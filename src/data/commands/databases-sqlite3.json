{
  "category": "sqlite3",
  "commands": [
    {
      "title": "Connect to SQLite3 Database",
      "template": "sqlite3 {database_file}"
    },
    {
      "title": "Show All Tables",
      "template": ".tables"
    },
    {
      "title": "Show Schema of a Table",
      "template": ".schema {table_name}"
    },
    {
      "title": "Print All Rows from a Table",
      "template": "SELECT * FROM {table_name};"
    },
    {
      "title": "Print Specific Column from a Table",
      "template": "SELECT {column_name} FROM {table_name};"
    },
    {
      "title": "Exit SQLite3 Console",
      "template": ".exit"
    }
  ]
}
