{
  "title": "Metasploit - Auxiliary & Reconnaissance",
  "commands": [
    {
      "args": [
        {
          "name": "rhhosts",
          "description": "Target IP/range",
          "default": "10.10.10.0/24"
        },
        {
          "name": "threads",
          "description": "Thread count",
          "default": "10"
        },
        {
          "name": "ports",
          "description": "Port range",
          "default": "1-10000"
        }
      ],
      "title": "TCP port scanner (connect scan)",
      "description": "Full TCP connect scan. Reliable but noisy. Scans all 10000 ports by default.",
      "template": "use auxiliary/scanner/portscan/tcp\\nset RHOSTS {rhhosts}\\nset THREADS {threads}\\nset PORTS {ports}\\nrun"
    },
    {
      "args": [
        {
